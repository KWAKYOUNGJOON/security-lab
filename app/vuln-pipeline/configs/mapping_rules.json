{
  "rules": [
    {
      "id": "reflected-xss-specific",
      "priority": 220,
      "stop_on_match": true,
      "logic": "all",
      "tools": ["nuclei", "burp"],
      "title_contains": ["reflected xss", "xss"],
      "tags_any": ["xss"],
      "response_highlight_contains": ["<svg", "<script"],
      "negative_tags": ["listing"],
      "weakness_family": "XSS",
      "primary_cwe": "CWE-79",
      "related_cwes": [],
      "owasp_top10_2025": ["A03 Injection"],
      "kisa_categories": ["스크립트 실행"],
      "references": ["CWE-79"]
